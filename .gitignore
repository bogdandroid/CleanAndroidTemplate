# Built application files
*.apk
*.aar
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/
*/build/
gradlew.bat

# Local configuration file (sdk path, etc)
local.properties

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ
*.iml
.idea/
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/assetWizardSettings.xml
.idea/dictionaries
.idea/libraries
# IntelliJ - Keep formatting settings
!.idea/codeStyles
!.idea/scopes

# Keystore files
*.jks
*.keystore

# External native build folder generated in Android Studio 2.2 and later
.externalNativeBuild/

# NDK
obj/

# CMake
CMakeLists.txt.user

# Google Services (e.g. APIs, Firebase)
google-services.json

# Mac OS
.DS_Store

# Version Catalogs & KSP temporary files
.ksp/

# IMPORTANT: Ensure the wrapper JAR is committed so others can build the project without installing Gradle manually.
# But ignore everything else in the gradle directory.
!gradle/wrapper/gradle-wrapper.jar
